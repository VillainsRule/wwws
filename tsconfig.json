{
    "compilerOptions": {
        "target": "ESNext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "declaration": true,
        "strict": true,
        "emitDeclarationOnly": false,
        "rootDir": ".",
        "outDir": "./dist",
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "types": ["bun"]
    },
    "include": [
        "src/**/*",
        "test/**/*"
    ]
}