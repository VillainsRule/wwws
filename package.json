{
    "name": "wwws",
    "description": "a worldwide (node, bun, & deno) websocket socks5/h proxy implementation",
    "version": "1.2.5",
    "keywords": [
        "websocket",
        "proxy",
        "socks",
        "socks5",
        "bun"
    ],
    "homepage": "https://github.com/VillainsRule/wwws",
    "bugs": {
        "url": "https://github.com/VillainsRule/wwws/issues"
    },
    "author": "VillainsRule",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/VillainsRule/wwws.git"
    },
    "type": "module",
    "files": [
        "dist/**/*",
        "package.json",
        "README.md"
    ],
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "browser": "dist/browser.js",
    "types": "dist/index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./browser": "./dist/browser.js"
    },
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.2.3",
        "@types/bun": "^1.3.3",
        "eslint": "^9.33.0",
        "globals": "^16.3.0",
        "tsdown": "^0.21.9",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "bun cli/build.js",
        "prod": "echo 'local publishing is blocked...run the github action!\nhttps://github.com/VillainsRule/wwws/actions/workflows/publish.yml'"
    }
}